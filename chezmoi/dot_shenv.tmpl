_ARCH=$(arch)
unset _ZPATH_LOADED

{{- if eq .chezmoi.os "darwin" }}
# https://mise.jdx.dev/configuration/environments.html
export MISE_ENV=development
# put this line into .env
# export MISE_ENV=development,ai
{{- end }}

# Resolve dotfiles root in a way that works for both symlink-managed and
# chezmoi-managed plain files.
if [ -d "$HOME/.local/share/chezmoi/" ]; then
  export _DOTFILES_PATH="$HOME/.local/share/chezmoi/"
elif [ -f "$HOME/.mydotfile" ]; then
  export _DOTFILES_PATH="$(cat "$HOME/.mydotfile")"
else
  export _DOTFILES_PATH="$HOME"
fi

export FZF_BASE=$_DOTFILES_PATH/vim/bundle/fzf

# export OPENAI_BASE_URL="http://ai.brill-ling.ts.net/v1"
# # fallback compibility
# export OPENAI_API_BASE=$OPENAI_BASE_URL
# export OPENAI_API_KEY="-"
# export ANTHROPIC_BASE_URL="http://ai.brill-ling.ts.net"
# export ANTHROPIC_AUTH_TOKEN="-"

export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8

if [ -n "$NVIM" ]; then
  export EDITOR=nvim
else
  export EDITOR=vim
fi

export GPG_TTY=$(tty)
export RUBY_BUILD_MIRROR_URL=https://cache.ruby-china.com

export MISE_RUBY_DEFAULT_PACKAGES_FILE=~/.rbenv/default-gems
# https://mise.jdx.dev/configuration.html#mise-use-toml-0
export MISE_USE_TOML=1
# avoid stuck vim if someone is not installed
# https://mise.jdx.dev/configuration.html#mise-not-found-auto-install-true
export MISE_NOT_FOUND_AUTO_INSTALL=false
# export MISE_ENV_FILE=.env

export ASDF_GEM_DEFAULT_PACKAGES_FILE=~/.rbenv/default-gems
export ASDF_GOLANG_DEFAULT_PACKAGES_FILE=~/.default-go-packages
export ASDF_GOLANG_MOD_VERSION_ENABLED=true
export ASDF_DIRENV_IGNORE_MISSING_PLUGINS=1

export PDM_USE_UV=true

export YAMLLINT_CONFIG_FILE=~/.yamllint.yaml

export XDG_RUNTIME_DIR="$HOME/.local/run"

{{- if eq .chezmoi.os "darwin" }}
export SSH_AUTH_SOCK=$(getconf DARWIN_USER_TEMP_DIR)/rbw-$(id -u)/ssh-agent-socket
{{- else if eq .chezmoi.os "linux" }}
export SSH_AUTH_SOCK="$XDG_RUNTIME_DIR/rbw/ssh-agent-socket"
{{- end }}

export HOMEBREW_NO_AUTO_UPDATE=1

if [ ! -S "$SSH_AUTH_SOCK" ]; then
  if [ -S "$HOME/.bitwarden-ssh-agent.sock" ]; then
    export SSH_AUTH_SOCK="$HOME/.bitwarden-ssh-agent.sock"
  else
    eval "$(ssh-agent -s)" >/dev/null
  fi
fi

if [ -f ~/.env ]; then
  set -o allexport; source ~/.env; set +o allexport
fi
