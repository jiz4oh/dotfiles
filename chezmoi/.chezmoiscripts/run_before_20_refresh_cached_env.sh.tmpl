#!/usr/bin/env bash
set -uo pipefail

SOURCE_DIR="{{ .chezmoi.sourceDir }}"
CONFIG_FILE="$SOURCE_DIR/.chezmoidata/cached-env.yaml"
CACHE_DIR="$HOME/.local/state/chezmoi"
CACHE_FILE="$CACHE_DIR/cached-env.env"

log() { echo "[cached-env] $*"; }
warn() { echo "[cached-env][warn] $*" >&2; }

if [ ! -f "$CONFIG_FILE" ]; then
  exit 0
fi

rows_file="$(mktemp)"
values_file="$(mktemp)"
trap 'rm -f "$rows_file" "$values_file"' EXIT

if ! ruby -ryaml - "$CONFIG_FILE" > "$rows_file" <<'RUBY'
path = ARGV.fetch(0)
config = YAML.safe_load(File.read(path), permitted_classes: [], aliases: false) || {}
entries = config.fetch("cached_env", [])
seen_names = {}

unless entries.is_a?(Array)
  warn "cached_env must be a list"
  exit 1
end

entries.each_with_index do |entry, index|
  unless entry.is_a?(Hash)
    warn "cached_env[#{index}] must be a map"
    exit 1
  end

  name = entry["name"].to_s
  rbw = entry["rbw"].to_s

  unless name.match?(/\A[A-Za-z_][A-Za-z0-9_]*\z/)
    warn "cached_env[#{index}].name is not a valid shell variable name: #{name.inspect}"
    exit 1
  end

  if seen_names[name]
    warn "cached_env[#{index}].name is duplicated: #{name}"
    exit 1
  end
  seen_names[name] = true

  if rbw.empty?
    warn "cached_env[#{index}].rbw is required"
    exit 1
  end

  if rbw.match?(/[\t\n]/)
    warn "cached_env[#{index}].rbw cannot contain a tab or newline"
    exit 1
  end

  puts ["rbw", name, rbw].join("\t")
end
RUBY
then
  warn "invalid cached env config, keep existing cache: $CONFIG_FILE"
  exit 0
fi

if [ ! -s "$rows_file" ]; then
  exit 0
fi

if ! command -v rbw >/dev/null 2>&1; then
  warn "rbw not found, keep existing cache: $CACHE_FILE"
  exit 0
fi

if ! rbw unlocked >/dev/null 2>&1; then
  warn "rbw locked or pinentry unavailable, keep existing cache: $CACHE_FILE"
  exit 0
fi

cached_value() {
  local name="$1"

  [ -r "$CACHE_FILE" ] || return 1

  (
    set +u
    # shellcheck disable=SC1090
    . "$CACHE_FILE" >/dev/null 2>&1 || exit 1
    value="${!name-}"
    [ -n "$value" ] || exit 1
    printf '%s' "$value"
  )
}

keep_cached_or_skip() {
  local name="$1"
  local ref="$2"
  local reason="$3"
  local old_value

  if old_value="$(cached_value "$name")"; then
    warn "$reason for $ref, keep cached $name"
    printf '%s\t%s\n' "$name" "$old_value" >> "$values_file"
  else
    warn "$reason for $ref, skip $name (no cached value)"
  fi
}

while IFS=$'\t' read -r provider name ref; do
  [ "${provider:-}" = "rbw" ] || continue

  if ! value="$(rbw get "$ref" 2>/dev/null)"; then
    keep_cached_or_skip "$name" "$ref" "rbw get failed"
    continue
  fi

  if [ -z "$value" ]; then
    keep_cached_or_skip "$name" "$ref" "rbw returned empty value"
    continue
  fi

  case "$value" in
    *$'\n'* | *$'\t'* )
      keep_cached_or_skip "$name" "$ref" "rbw value contains a newline or tab"
      continue
      ;;
  esac

  printf '%s\t%s\n' "$name" "$value" >> "$values_file"
done < "$rows_file"

if [ ! -s "$values_file" ]; then
  exit 0
fi

if ! mkdir -p "$CACHE_DIR"; then
  warn "failed to create cache dir, keep existing cache: $CACHE_DIR"
  exit 0
fi

chmod 700 "$CACHE_DIR" 2>/dev/null || true

if ! tmp="$(mktemp "$CACHE_FILE.XXXXXX")"; then
  warn "failed to create temporary cache file, keep existing cache: $CACHE_FILE"
  exit 0
fi

if ! {
  printf '# Generated by chezmoi. Do not commit.\n'
  printf '# Refreshed from %s; kept unchanged when refresh is unavailable.\n' "$CONFIG_FILE"

  while IFS=$'\t' read -r name value; do
    printf 'export %s=' "$name"
    printf '%q' "$value"
    printf '\n'
  done < "$values_file"
} > "$tmp"; then
  warn "failed to write temporary cache file, keep existing cache: $CACHE_FILE"
  rm -f "$tmp"
  exit 0
fi

chmod 600 "$tmp" 2>/dev/null || true

if ! mv "$tmp" "$CACHE_FILE"; then
  warn "failed to replace cache file, keep existing cache: $CACHE_FILE"
  rm -f "$tmp"
  exit 0
fi

log "refreshed cache: $CACHE_FILE"
exit 0
