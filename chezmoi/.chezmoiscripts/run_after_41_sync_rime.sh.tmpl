#!/usr/bin/env bash
set -euo pipefail

SOURCE_DIR="{{ .chezmoi.sourceDir }}"
ROOT_DIR="$(cd "$SOURCE_DIR/.." && pwd)"
UPSTREAM_DIR="$HOME/.local/share/rime-frost"
STATE_DIR="$HOME/.local/state/chezmoi"
STATE_FILE="$STATE_DIR/rime-sync.state"

log() { echo "[rime-init] $*"; }
warn() { echo "[rime-init][warn] $*" >&2; }

if [ ! -d "$UPSTREAM_DIR" ]; then
  warn "missing upstream dir: $UPSTREAM_DIR"
  exit 0
fi

hash_dir_files() {
  local dir="$1"
  if [ ! -d "$dir" ]; then
    printf "missing"
    return
  fi
  if [ -z "$(find "$dir" -type f -print -quit 2>/dev/null)" ]; then
    printf "empty"
    return
  fi
  (
    cd "$dir"
    find . -type f -print0 \
      | sort -z \
      | xargs -0 shasum
  ) | shasum | awk '{print $1}'
}

upstream_rev="$(git -C "$UPSTREAM_DIR" rev-parse HEAD 2>/dev/null || echo "nogit")"
custom_hash="$(hash_dir_files "$ROOT_DIR/rime/custom")"
opencc_hash="$(hash_dir_files "$ROOT_DIR/rime/opencc")"
new_state="upstream=${upstream_rev};custom=${custom_hash};opencc=${opencc_hash}"
old_state="$(cat "$STATE_FILE" 2>/dev/null || true)"

if [ "$new_state" = "$old_state" ]; then
  log "skip sync (no change)"
  exit 0
fi

{{- if eq .chezmoi.os "darwin" }}
ROOT_DIR="$ROOT_DIR" UPSTREAM_DIR="$UPSTREAM_DIR" bash "$ROOT_DIR/rime/install_osx" || warn "install_osx sync handling failed"
{{- end }}

mkdir -p "$STATE_DIR"
printf '%s\n' "$new_state" > "$STATE_FILE"
