#!/usr/bin/env bash
set -euo pipefail

{{- if ne .chezmoi.os "linux" }}
exit 0
{{- end }}

# Only run on explicit VPS bootstrap, e.g. from Ansible:
# CHEZMOI_VPS_BOOTSTRAP=1 SSH_PORT=23232 chezmoi init --apply ...
[ "${CHEZMOI_VPS_BOOTSTRAP:-0}" = "1" ] || exit 0

if [ "$(id -u)" -eq 0 ]; then
  SUDO=""
else
  SUDO="sudo"
fi

SSH_PORT="${SSH_PORT:-23232}"
SOURCE_DIR="{{ .chezmoi.sourceDir }}"
ROOT_DIR="$(cd "$SOURCE_DIR/.." && pwd)"
BOOTSTRAP_DIR="$ROOT_DIR/vps/bootstrap"

if command -v apt-get >/dev/null 2>&1; then
  $SUDO apt-get update -y
  $SUDO apt-get install -y -qq --no-install-recommends sudo zsh neovim git curl wget kitty-terminfo >/dev/null || true
elif command -v yum >/dev/null 2>&1; then
  $SUDO yum install -y sudo zsh neovim git curl wget >/dev/null || true
fi

# sshd hardening drop-in
$SUDO mkdir -p /etc/ssh/sshd_config.d
if [ -f "$BOOTSTRAP_DIR/sshd_config.conf" ]; then
  tmp_sshd="$(mktemp)"
  trap 'rm -f "${tmp_sshd:-}"' EXIT
  sed "s/__SSH_PORT__/${SSH_PORT}/g" "$BOOTSTRAP_DIR/sshd_config.conf" > "$tmp_sshd"
  $SUDO install -m 0644 "$tmp_sshd" /etc/ssh/sshd_config.d/01_jiz4oh.conf
fi
if command -v systemctl >/dev/null 2>&1; then
  $SUDO systemctl restart ssh 2>/dev/null || $SUDO systemctl restart sshd 2>/dev/null || true
fi

# TCP BBR (idempotent)
if ! grep -q '^net.core.default_qdisc=fq$' /etc/sysctl.conf 2>/dev/null; then
  echo "net.core.default_qdisc=fq" | $SUDO tee -a /etc/sysctl.conf >/dev/null
fi
if ! grep -q '^net.ipv4.tcp_congestion_control=bbr$' /etc/sysctl.conf 2>/dev/null; then
  echo "net.ipv4.tcp_congestion_control=bbr" | $SUDO tee -a /etc/sysctl.conf >/dev/null
fi
$SUDO sysctl -p >/dev/null 2>&1 || true

# Docker + daemon config
$SUDO mkdir -p /etc/docker
if [ -f "$BOOTSTRAP_DIR/docker-daemon.json" ] && [ ! -f /etc/docker/daemon.json ]; then
  $SUDO install -m 0644 "$BOOTSTRAP_DIR/docker-daemon.json" /etc/docker/daemon.json
fi
if ! command -v docker >/dev/null 2>&1; then
  curl -fsSL https://get.docker.com | $SUDO bash
fi

# Default shell
if command -v zsh >/dev/null 2>&1; then
  chsh -s "$(command -v zsh)" "$(id -un)" 2>/dev/null || true
fi
