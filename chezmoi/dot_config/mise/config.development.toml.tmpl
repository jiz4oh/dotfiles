[tools]
ruby = { version = "3.1.2", postinstall = "{{- .chezmoi.homeDir -}}/.local/share/chezmoi/mise-ruby-ctags/bin/mise-ruby-ctags \"$MISE_TOOL_INSTALL_PATH\"" }
node = "lts"
go = "latest"
"go:github.com/lemonade-command/lemonade" = "latest"
python = ["latest", "prefix:3.11"]
uv = "latest"
pdm = "latest"

"npm:prettier" = "latest"
"npm:prettier-eslint-cli" = "latest"
"npm:prettier-plugin-erb" = "latest"
"npm:eslint-config-prettier" = "latest"
"npm:eslint" = "latest"
"npm:eslint-plugin-html" = "latest"
"npm:eslint-plugin-prettier" = "latest"
"npm:stylelint" = "latest"
"npm:stylelint-config-standard-scss" = "latest"
"npm:stylelint-prettier" = "latest"
"npm:wrangler" = "latest"
"gem:rubocop" = "latest"
"gem:ripper-tags" = "latest"
# support ruby >= 2.4.0
"pipx:ansible" = "latest"

[settings]
experimental = true
python.uv_venv_auto = true
idiomatic_version_file_enable_tools = ["ruby", "python"]

[settings.node]
gpg_verify = false
