#!/usr/bin/env bash

set -euo pipefail

cd "$(dirname "${BASH_SOURCE[0]}")" || exit 1
BASE=$(pwd)

if ! command -v chezmoi >/dev/null 2>&1; then
  echo "chezmoi is required. Install it first:" >&2
  echo "  brew install chezmoi" >&2
  echo "  or: sh -c \"\$(curl -fsLS get.chezmoi.io)\" -- -b \"\$HOME/.local/bin\"" >&2
  exit 1
fi

exec chezmoi --source "$BASE" apply --force --no-tty
