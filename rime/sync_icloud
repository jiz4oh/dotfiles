#!/usr/bin/env bash

set -euo pipefail

ICLOUD_DIR="$HOME/Library/Mobile Documents/iCloud~dev~fuxiao~app~hamsterapp/Documents/sync/"
LOCAL_DIR="$(cat "$HOME/.mybackups")/rime/"
RSYNC_OPTIONS=(-avhu)
EXCLUDES=(
  --exclude=.DS_Store
  --exclude=.git
  --exclude=.svn
  --exclude=*.swp
  --exclude=*.swo
  --exclude=*.icloud
)

if [ ! -d "$ICLOUD_DIR" ]; then
  echo "错误：iCloud 目录未找到: $ICLOUD_DIR" >&2
  exit 1
fi

if [ ! -d "$LOCAL_DIR" ]; then
  echo "错误：本地目录未找到: $LOCAL_DIR" >&2
  exit 1
fi

rsync "${RSYNC_OPTIONS[@]}" "${EXCLUDES[@]}" "$ICLOUD_DIR" "$LOCAL_DIR"
rsync "${RSYNC_OPTIONS[@]}" "${EXCLUDES[@]}" "$LOCAL_DIR" "$ICLOUD_DIR"
