#!/usr/bin/env bash

set -euo pipefail

log() {
  echo "[rime-android] $*"
}

if [ -z "${1:-}" ]; then
  echo "用法: $0 <目标目录>" >&2
  exit 1
fi

TARGET_DIR="$1"
BASE="$(cd "$(dirname "$(dirname "$(realpath "${BASH_SOURCE[0]}")")")" && pwd)"
UPSTREAM_DIR="$HOME/.local/share/rime-frost"
LOCAL_TMP_DIR="$(mktemp -d)"
trap 'rm -rf "$LOCAL_TMP_DIR"' EXIT
STAGE_DIR="$LOCAL_TMP_DIR/rime"
ARCHIVE_PATH="$LOCAL_TMP_DIR/rime-android.zip"
REMOTE_TMP_DIR="/sdcard/Download/rime-install"
REMOTE_ARCHIVE_PATH="$REMOTE_TMP_DIR/rime-android.zip"
REMOTE_EXTRACT_DIR="$REMOTE_TMP_DIR/extracted"

command -v adb >/dev/null 2>&1 || { log "错误：需要 adb 命令。" >&2; exit 1; }
command -v zip >/dev/null 2>&1 || { log "错误：需要 zip 命令。" >&2; exit 1; }
[ -d "$UPSTREAM_DIR" ] || { log "错误：缺少 upstream 目录 $UPSTREAM_DIR" >&2; exit 1; }

log "staging files from upstream"
mkdir -p "$STAGE_DIR"
rsync -a --delete --exclude '.git/' --exclude 'sync/' "$UPSTREAM_DIR/" "$STAGE_DIR/"
cp "$BASE"/rime/custom/* "$STAGE_DIR/"
mkdir -p "$STAGE_DIR/opencc"
cp "$BASE"/rime/opencc/* "$STAGE_DIR/opencc/"
cp -f "$UPSTREAM_DIR/rime_frost.dict.yaml" "$STAGE_DIR/pinyin_flypy.dict.yaml"

log "creating archive $ARCHIVE_PATH"
(
  cd "$STAGE_DIR"
  zip -qr "$ARCHIVE_PATH" .
)

log "probing unzip support on device"
if adb shell "command -v unzip >/dev/null 2>&1"; then
  UNZIP_CMD="unzip"
elif adb shell "toybox unzip -h >/dev/null 2>&1"; then
  UNZIP_CMD="toybox unzip"
else
  log "错误：设备端缺少 unzip 或 toybox unzip，无法解压压缩包。" >&2
  exit 1
fi

log "preparing remote temp dir"
adb shell "rm -rf '$REMOTE_TMP_DIR' && mkdir -p '$REMOTE_TMP_DIR' '$TARGET_DIR'"

log "pushing archive to device"
adb push "$ARCHIVE_PATH" "$REMOTE_ARCHIVE_PATH"

log "extracting archive on device"
adb shell "rm -rf '$REMOTE_EXTRACT_DIR' && mkdir -p '$REMOTE_EXTRACT_DIR' && $UNZIP_CMD -o '$REMOTE_ARCHIVE_PATH' -d '$REMOTE_EXTRACT_DIR' >/dev/null"

log "replacing target contents on device"
adb shell "find '$TARGET_DIR' -mindepth 1 -maxdepth 1 -exec rm -rf {} + && cp -a '$REMOTE_EXTRACT_DIR'/.' '$TARGET_DIR'/"

log "cleaning remote temp dir"
adb shell "rm -rf '$REMOTE_TMP_DIR'"

log "done: $TARGET_DIR"
