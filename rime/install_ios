#!/usr/bin/env bash

set -euo pipefail

command -v rsync >/dev/null 2>&1 || { echo "错误：需要 rsync 命令。" >&2; exit 1; }

BASE="$(cd "$(dirname "$(dirname "$(realpath "${BASH_SOURCE[0]}")")")" && pwd)"
UPSTREAM_DIR="$HOME/.local/share/rime-frost"
HAMSTER_DIR="$HOME/Library/Mobile Documents/iCloud~dev~fuxiao~app~hamsterapp/Documents/RIME/Rime"
HAMSTER3_DIR="$HOME/Library/Mobile Documents/iCloud~com~ihsiao~apps~Hamster3/Documents/RimeUserData/jiz4oh"
WORK_DIR="$(mktemp -d)"
trap 'rm -rf "$WORK_DIR"' EXIT
STAGE_DIR="$WORK_DIR/rime"

[ -d "$UPSTREAM_DIR" ] || { echo "错误：缺少 upstream 目录 $UPSTREAM_DIR" >&2; exit 1; }

mkdir -p "$STAGE_DIR"
rsync -a --delete --exclude '.git/' --exclude 'sync/' "$UPSTREAM_DIR/" "$STAGE_DIR/"
cp "$BASE"/rime/custom/* "$STAGE_DIR/"
mkdir -p "$STAGE_DIR/opencc"
cp "$BASE"/rime/opencc/* "$STAGE_DIR/opencc/"
ln -sfn "$UPSTREAM_DIR/rime_frost.dict.yaml" "$STAGE_DIR/pinyin_flypy.dict.yaml"
find "$STAGE_DIR" -mindepth 1 -name '.*' -exec rm -rf {} +

mkdir -p "$HAMSTER_DIR" "$HAMSTER3_DIR"
rsync -a "$STAGE_DIR/" "$HAMSTER_DIR/"
rsync -a "$STAGE_DIR/" "$HAMSTER3_DIR/"
