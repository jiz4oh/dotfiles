#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BASE="$(cd "$SCRIPT_DIR/.." && pwd)"
SKILLS_EXTERNALS_FILE="$BASE/chezmoi/.chezmoiexternals/skills.toml"
SKILLS_EXTERNALS_TEMPLATE="$BASE/chezmoi/.chezmoiexternals/skills.toml.tmpl"
SKILLS_DIR="$BASE/chezmoi/dot_agents/skills"
PRUNE="${PRUNE:-0}"

usage() {
  cat <<'EOF'
Usage:
  scripts/install_skills

Environment:
  PRUNE=1   remove stale symlink_* entries not declared in .chezmoiexternals/skills.toml

This script treats .chezmoiexternals/skills.toml(.tmpl) as the source of truth
for external skill entrypoints. It reads x.skills from
.agents/skill-sources/* sections and generates chezmoi source files under:
  chezmoi/dot_agents/skills/symlink_<skill-name>

Local first-party skills should remain as real directories in:
  chezmoi/dot_agents/skills/<skill-name>/
EOF
}

if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
  usage
  exit 0
fi

if [ ! -f "$SKILLS_EXTERNALS_FILE" ]; then
  if [ ! -f "$SKILLS_EXTERNALS_TEMPLATE" ]; then
    echo "missing skills externals file: $SKILLS_EXTERNALS_FILE" >&2
    echo "missing skills externals template: $SKILLS_EXTERNALS_TEMPLATE" >&2
    exit 1
  fi
fi

if [ ! -d "$SKILLS_DIR" ]; then
  echo "missing skills dir: $SKILLS_DIR" >&2
  exit 1
fi

warn() {
  echo "warn: $*" >&2
}

created=0
updated=0
unchanged=0
warnings=0
declared_names=()
skill_rows_file="$(mktemp)"
skills_config_file="$(mktemp)"
trap 'rm -f "$skill_rows_file" "$skills_config_file"' EXIT

if [ -f "$SKILLS_EXTERNALS_TEMPLATE" ]; then
  chezmoi --source "$BASE" execute-template < "$SKILLS_EXTERNALS_TEMPLATE" > "$skills_config_file"
else
  cp "$SKILLS_EXTERNALS_FILE" "$skills_config_file"
fi

ruby - "$skills_config_file" > "$skill_rows_file" <<'RUBY'
path = ARGV.fetch(0)
lines = File.readlines(path, chomp: true)
current_section = nil
i = 0

while i < lines.length
  line = lines[i]

  if (match = line.match(/^\["([^"]+)"\]\s*$/))
    current_section = match[1]
    i += 1
    next
  end

  if current_section && line =~ /^\s*x\.skills\s*=\s*\[/
    block = line.dup
    until block.include?("]")
      i += 1
      break if i >= lines.length
      block << "\n" << lines[i]
    end

    unless (section_match = current_section.match(/^\.agents\/skill-sources\/([^\/]+)$/))
      puts ["warn", "skip x.skills under unsupported external path '#{current_section}'"].join("\t")
      i += 1
      next
    end

    source_id = section_match[1]
    block.scan(/"([^"]+)"/).flatten.each do |item|
      name, relpath = item.split("=", 2)
      next if name.nil? || name.empty? || relpath.nil? || relpath.empty?
      puts ["row", source_id, name, relpath].join("\t")
    end
  end

  i += 1
end
RUBY

while IFS=$'\t' read -r row_type field1 field2 field3; do
  if [ "${row_type:-}" = "warn" ]; then
    warn "$field1"
    warnings=$((warnings + 1))
    continue
  fi

  [ "${row_type:-}" = "row" ] || continue

  source_id="$field1"
  skill_name="$field2"
  source_subdir="$field3"

  [ -z "${source_id:-}" ] && continue
  [ -z "${skill_name:-}" ] && continue
  [ -z "${source_subdir:-}" ] && continue

  case "$skill_name" in
    */* | .* | *".."* )
      warn "skip unsafe skill name '$skill_name'"
      warnings=$((warnings + 1))
      continue
      ;;
  esac

  case "$source_subdir" in
    "" | /* | *".."* )
      warn "skip unsafe source subdir '$source_subdir' for skill '$skill_name'"
      warnings=$((warnings + 1))
      continue
      ;;
  esac

  target_path="../skill-sources/$source_id"
  if [ "$source_subdir" != "." ]; then
    target_path="$target_path/$source_subdir"
  fi

  entry_path="$SKILLS_DIR/symlink_$skill_name"
  declared_names+=("$skill_name")
  source_base="$HOME/.agents/skill-sources/$source_id"
  source_path="$source_base"
  if [ "$source_subdir" != "." ]; then
    source_path="$source_base/$source_subdir"
  fi

  if [ ! -d "$source_base" ]; then
    warn "skip skill '$skill_name': missing skill source '$source_base'"
    warnings=$((warnings + 1))
    continue
  fi

  if [ ! -e "$source_path" ]; then
    warn "skip skill '$skill_name': missing declared path '$source_path'"
    warnings=$((warnings + 1))
    continue
  fi

  if [ -d "$SKILLS_DIR/$skill_name" ]; then
    warn "local skill dir exists, keep directory and skip symlink_$skill_name"
    warnings=$((warnings + 1))
    continue
  fi

  if [ -f "$entry_path" ]; then
    current="$(cat "$entry_path")"
    if [ "$current" = "$target_path" ]; then
      unchanged=$((unchanged + 1))
      continue
    fi
    printf '%s\n' "$target_path" > "$entry_path"
    updated=$((updated + 1))
    continue
  fi

  printf '%s\n' "$target_path" > "$entry_path"
  created=$((created + 1))
done < "$skill_rows_file"

for entry_path in "$SKILLS_DIR"/symlink_*; do
  [ -e "$entry_path" ] || continue
  skill_name="${entry_path##*/symlink_}"

  declared=0
  for known_name in "${declared_names[@]}"; do
    if [ "$known_name" = "$skill_name" ]; then
      declared=1
      break
    fi
  done

  if [ "$declared" -eq 1 ]; then
    continue
  fi

  if [ "$PRUNE" = "1" ]; then
    rm -f "$entry_path"
    echo "pruned: symlink_$skill_name"
  else
    warn "undeclared symlink preserved: symlink_$skill_name"
    warnings=$((warnings + 1))
  fi
done

echo "skills sync complete"
echo "  created:   $created"
echo "  updated:   $updated"
echo "  unchanged: $unchanged"
echo "  warnings:  $warnings"
